# Arvyon Agent configuration (copy to .env and fill in)

# --- Identity & policy (dynamic; nothing hardcoded) ---
# The agent address is derived from ARVYON_PRIVATE_KEY. Without a key, set an
# explicit address here for read-only / mock runs.
# ARVYON_AGENT_ADDRESS=
# Policy definition file. Its canonical keccak256 is the on-chain policy hash.
# ARVYON_POLICY_FILE=agent/policy.json
# Iterations of the observe->decide->intent->submit loop.
ARVYON_ITERATIONS=1

# --- LLM (DecideNode) — provider-agnostic ---
# Choose how the agent reasons. With no provider configured it uses a
# rule-based fallback (clearly labeled, NOT AI). Set ONE of the following:
#
#   ARVYON_LLM_PROVIDER = anthropic | openai | auto   (default: auto)
#
# Option A — Anthropic (Claude):
ANTHROPIC_API_KEY=
#
# Option B (recommended, free) — local Ollama, ZERO config:
#   Just run `ollama serve` and `ollama pull llama3.1`. In auto mode the agent
#   detects the running Ollama and auto-selects an installed model. Nothing to
#   set here. (Override the host with ARVYON_OLLAMA_HOST if not on :11434.)
# ARVYON_OLLAMA_HOST=http://localhost:11434
#
# Option C — any other OpenAI-COMPATIBLE endpoint (OpenAI, OpenRouter, Groq, ...):
#   ARVYON_LLM_BASE_URL   e.g. http://localhost:11434/v1   (Ollama, free/local)
#                              https://openrouter.ai/api/v1 (OpenRouter)
#                              https://api.openai.com/v1    (OpenAI; or leave unset)
#   ARVYON_LLM_API_KEY    provider key (use any value for local Ollama)
#   ARVYON_LLM_MODEL      e.g. llama3.1 | gpt-4o-mini | claude-opus-4-8
# ARVYON_LLM_PROVIDER=openai
# ARVYON_LLM_BASE_URL=http://localhost:11434/v1
# ARVYON_LLM_API_KEY=ollama
# ARVYON_LLM_MODEL=llama3.1

# --- Market simulation (ObserveNode) ---
# Fix the simulated market for reproducible runs; omit for random each run.
# ARVYON_MARKET_SEED=7
# ARVYON_BALANCE=500

# --- ZK proofs (IntentNode) ---
# Set to 1 to generate real Groth16 proofs via snarkjs (slower).
# REQUIRED for genuine on-chain proof verification (executor mode).
ARVYON_REAL_ZK=0

# --- On-chain submission (SubmitNode) ---
# JSON-RPC endpoint (Sepolia). On-chain steps are skipped if unset.
ARVYON_RPC_URL=
# Agent account private key. Required to broadcast transactions; it is the
# msg.sender and must have a policy registered in PolicyRegistry.
ARVYON_PRIVATE_KEY=
# Build/estimate transactions but never broadcast them.
ARVYON_DRY_RUN=0
# Which on-chain path to use:
#   pdr      (default) - log the compliance result to PDRLogger (no proof check)
#   executor           - submit the proof to Executor.executeWithVerification,
#                        which verifies the ZK proof ON-CHAIN (set ARVYON_REAL_ZK=1)
#   both
# For genuine on-chain proof: ARVYON_REAL_ZK=1 and ARVYON_SUBMIT_MODE=executor,
# and the agent address must have a policy registered on-chain.
ARVYON_SUBMIT_MODE=pdr

# Optional address overrides (defaults come from contracts/deployments.json)
# ARVYON_POLICY_REGISTRY_ADDR=
# ARVYON_EXECUTOR_ADDR=
# ARVYON_PDR_LOGGER_ADDR=
