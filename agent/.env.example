# Arvyon Agent configuration (copy to .env and fill in)

# --- LLM (DecideNode) ---
# If unset, the agent uses deterministic mock decisions.
ANTHROPIC_API_KEY=

# --- ZK proofs (IntentNode) ---
# Set to 1 to generate real Groth16 proofs via snarkjs (slower).
# Leave 0 for fast mock compliance checks.
ARVYON_REAL_ZK=0

# --- On-chain submission (SubmitNode) ---
# JSON-RPC endpoint (Sepolia). On-chain steps are skipped if unset.
ARVYON_RPC_URL=
# Agent account private key. Required to broadcast transactions; it is the
# msg.sender and must have a policy registered in PolicyRegistry.
ARVYON_PRIVATE_KEY=
# Build/estimate transactions but never broadcast them.
ARVYON_DRY_RUN=0
# Which on-chain path to use: pdr (default) | executor | both
ARVYON_SUBMIT_MODE=pdr

# Optional address overrides (defaults come from contracts/deployments.json)
# ARVYON_POLICY_REGISTRY_ADDR=
# ARVYON_EXECUTOR_ADDR=
# ARVYON_PDR_LOGGER_ADDR=
